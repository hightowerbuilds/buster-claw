<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements. The audio-input entitlement is required for a
  notarized build to access the microphone (voice roadmap Phase 2); without it a
  signed app is denied mic access regardless of the Info.plist usage string.
  Referenced from tauri.conf.json -> bundle.macOS.entitlements. Add further
  entitlements here as the Apple-signing critical path comes online.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
