{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buster Claw",
  "version": "0.1.0",
  "identifier": "lol.busterclaw.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:4000",
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Buster Claw",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "resources": {
      "resources/release": "release"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist"
    }
  }
}
