{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buster Claw Rewrite",
  "version": "0.1.0",
  "identifier": "com.hightowerbuilds.busterclaw.rewrite",
  "build": {
    "devUrl": "http://127.0.0.1:4000",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Buster Claw Rewrite",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
