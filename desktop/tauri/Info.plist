<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Merged into the generated Info.plist at bundle time (Tauri v2 picks up a
  project-root Info.plist automatically). The microphone usage string is what
  macOS shows the first time voice input requests mic access (voice roadmap
  Phase 2). Required for the prompt to appear at all on a hardened-runtime build.
-->
<plist version="1.0">
<dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>Buster Claw uses the microphone for voice input in chat.</string>
</dict>
</plist>
