{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for the Buster Claw desktop shell.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "permissions": [
    "core:default",
    "allow-terminal-open",
    "allow-terminal-attach",
    "allow-terminal-input",
    "allow-terminal-resize",
    "allow-terminal-busy",
    "allow-terminal-close",
    "allow-browser-open",
    "allow-browser-set-bounds",
    "allow-browser-navigate",
    "allow-browser-back",
    "allow-browser-forward",
    "allow-browser-reload",
    "allow-browser-hide",
    "allow-browser-close",
    "allow-browser-screenshot",
    "allow-browser-current",
    "allow-browser-navigate-active",
    "allow-browser-open-tab-active",
    "allow-browser-read-active",
    "allow-browser-find-elements-active",
    "allow-browser-click-active",
    "allow-browser-fill-active",
    "allow-browser-wait-active",
    "allow-browser-extract-active",
    "allow-browser-render-page",
    "allow-speak",
    "allow-stop-speaking"
  ]
}
