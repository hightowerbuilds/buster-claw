{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for the Buster Claw desktop shell.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "permissions": [
    "core:default",
    "allow-terminal-open",
    "allow-terminal-attach",
    "allow-terminal-input",
    "allow-terminal-resize",
    "allow-terminal-close",
    "allow-workspace-relaunch"
  ]
}
