{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "browser-chrome",
  "description": "The embedded browser's native chrome toolbar (address bar + nav). Loaded from the Phoenix loopback origin; may drive the content webview.",
  "webviews": ["browser-chrome-*"],
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "permissions": [
    "core:default",
    "allow-browser-navigate",
    "allow-browser-back",
    "allow-browser-forward",
    "allow-browser-reload",
    "allow-browser-new-tab",
    "allow-browser-switch-tab",
    "allow-browser-close-tab",
    "allow-browser-app-navigate",
    "allow-browser-set-sidebar",
    "allow-browser-reveal-download",
    "allow-browser-set-zoom",
    "allow-browser-find",
    "allow-browser-find-count",
    "allow-browser-set-content-blocking"
  ]
}
