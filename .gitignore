.DS_Store

# Phoenix generated files
/_build/
/cover/
/deps/
/doc/
/.fetch
*.ez
/tmp/
buster_claw-*.tar
/priv/static/assets/
/priv/static/cache_manifest.json
# Phoenix digest hashed copies + precompressed assets
/priv/static/*-*.ico
/priv/static/*-*.txt
/priv/static/*.gz
/assets/node_modules/
/priv/playwright_sidecar/node_modules/
npm-debug.log
*.db
*.db-*

# Tauri desktop shell generated files
desktop/tauri/target/
# Bundled whisper STT model (~142MB) — fetched, not committed
# (scripts/fetch_whisper_model.sh). Keep the dir via its .gitkeep.
desktop/tauri/resources/models/*.bin

# Local runtime data
/Library/
# Workspace artifacts when the repo itself is the dev workspace
/shift/
/memory/
/job-descriptions/
/analysis/
/sources/
/projects/
# Brand art (wordmarks / logo / backgrounds) — local-only, kept out of the repo
/priv/static/images/brand/
*.log
erl_crash.dump

# CLI escript build artifact
/buster-claw

# Stray root-level npm cruft (not part of this Elixir/esbuild project)
/node_modules/
/package.json
/bun.lock

# Local environment / secrets (never commit)
.env
.env.local
_plts/

# Claude Code local session data (agent worktrees, settings)
/.claude/

# Supabase CLI version-check cache — pure noise, changes on every CLI release.
supabase/.temp/cli-latest
